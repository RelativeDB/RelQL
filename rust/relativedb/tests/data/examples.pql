PREDICT COUNT(transaction.*) OVER (7 DAYS FOLLOWING) FOR EACH user.user_id WHERE COUNT(transaction.* WHERE transaction.value > 10) OVER (7 DAYS PRECEDING) > 0
PREDICT COUNT(session.*) OVER (7 DAYS FOLLOWING) > 10 OR SUM(transaction.value) OVER (5 DAYS FOLLOWING) > 100 FOR EACH user.user_id
