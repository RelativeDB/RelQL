PREDICT LAST(payments.amount) OVER (90 DAYS FOLLOWING) == 0 FOR EACH order.order_id WHERE order.location == 'US'
PREDICT SUM(sales.qty) OVER (7 DAYS FOLLOWING HORIZONS 4) FOR EACH stores.store_id AS OF :prediction_time RETURN EXPECTED VALUE
