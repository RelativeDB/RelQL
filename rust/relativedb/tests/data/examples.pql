PREDICT LOAN.STATUS IN ('A', 'C') FOR EACH LOAN.id
PREDICT ARTICLES.DESCRIPTION IS NULL FOR EACH ARTICLES.id
PREDICT NOT LAST(LOAN.AMOUNT) OVER (30 DAYS FOLLOWING) > 30 FOR EACH LOAN.id
PREDICT COUNT(transactions.*) OVER (UNBOUNDED PRECEDING) > 0 FOR EACH user.user_id
