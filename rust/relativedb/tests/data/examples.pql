PREDICT SUM(payments.amount) OVER (30 DAYS FOLLOWING) FOR EACH customers.customer_id AS OF :t RETURN INTERVAL 90%
PREDICT GREATEST(SUM(orders.revenue) OVER (30 DAYS FOLLOWING), 0) * 2 FOR EACH customers.customer_id
