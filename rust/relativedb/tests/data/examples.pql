PREDICT CUSTOMERS.industry FOR EACH CUSTOMERS.CUSTOMER_ID
PREDICT SUM(PURCHASES.amount) OVER (30 DAYS FOLLOWING) > 10 FOR EACH USERS.user_id
PREDICT LAST(STATUS.status) OVER (90 DAYS FOLLOWING) = 'INACTIVE' FOR EACH USERS.user_id
