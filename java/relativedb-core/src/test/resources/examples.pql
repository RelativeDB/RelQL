PREDICT SUM(TRANSACTIONS.PRICE, 0, 30) FOR EACH CUSTOMERS.CUSTOMER_ID
PREDICT SUM(TRANSACTIONS.PRICE, 10, 30) FOR EACH CUSTOMERS.CUSTOMER_ID
PREDICT SUM(TRANSACTIONS.PRICE, 0, 30, months) FOR EACH CUSTOMERS.CUSTOMER_ID
PREDICT SUM(TRANSACTIONS.PRICE, 0, 30) FOR EACH CUSTOMERS.CUSTOMER_ID WHERE COUNT(TRANSACTIONS.*, -30, 0) > 0
PREDICT COUNT(transactions.*, 0, 30, days) = 0 FOR EACH customers.customer_id WHERE COUNT(transactions.*, -90, 0, days) > 0
PREDICT COUNT(transactions.*, 0, 30, days) = 0 FOR EACH CUSTOMERS.CUSTOMER_ID
PREDICT SUM(PURCHASES.amount, 0, 30) FOR EACH USERS.user_id
PREDICT LIST_DISTINCT(PURCHASES.item_category, 0, 14) FOR EACH USERS.user_id
PREDICT CUSTOMERS.industry FOR EACH CUSTOMERS.CUSTOMER_ID
PREDICT SUM(PURCHASES.amount, 0, 30) > 10 FOR EACH USERS.user_id
PREDICT LAST(STATUS.status, 0, 90) = 'INACTIVE' FOR EACH USERS.user_id
PREDICT SUM(PURCHASES.amount, 0, 30) > 10 OR COUNT(VIEWS.*, 0, 30) > 20 FOR EACH USERS.user_id
PREDICT CUSTOMERS.industry = 'IT' AND CUSTOMERS.date_of_birth <= 1990-01-01 FOR EACH CUSTOMERS.CUSTOMER_ID
PREDICT LIST_DISTINCT(TRANSACTIONS.ARTICLE_ID, 0, 30) CLASSIFY FOR EACH CUSTOMERS.CUSTOMER_ID
PREDICT LIST_DISTINCT(TRANSACTIONS.ARTICLE_ID, 0, 30) RANK TOP 12 FOR EACH CUSTOMERS.CUSTOMER_ID
PREDICT target.multicategorical_column RANK TOP 20 FOR EACH target.id
PREDICT SUM(TRANSACTIONS.PRICE, 0, 30) FOR EACH CUSTOMERS.CUSTOMER_ID ASSUMING COUNT(NOTIFICATIONS.*, 0, 7) > 2
PREDICT SUM(TRANSACTIONS.PRICE, 0, 30) FOR EACH CUSTOMERS.CUSTOMER_ID ASSUMING LIST_DISTINCT(COUPONS.type, 0, 3) CONTAINS '50 percent off'
PREDICT SUM(TRANSACTIONS.PRICE, 0, 30) FOR EACH CUSTOMERS.CUSTOMER_ID ASSUMING COUNT(NOTIFICATIONS.*, 0, 7) > 5 AND SUM(NOTIFICATIONS.LENGTH, 0, 7) > 10
PREDICT COUNT(transaction.* WHERE transaction.amount > 100) FOR EACH user.user_id WHERE user.country = 'US'
PREDICT COUNT(transaction.* WHERE transaction.value > 10, 0, 7) FOR EACH user.user_id WHERE COUNT(transaction.*, -7, 0) > 0
PREDICT COUNT(transaction.*, 0, 7) FOR EACH user.user_id WHERE COUNT(transaction.* WHERE transaction.value > 10, -7, 0) > 0
PREDICT COUNT(session.*, 0, 7) > 10 OR SUM(transaction.value, 0, 5) > 100 FOR EACH user.user_id
PREDICT LIST_DISTINCT(transactions.article_id WHERE articles.product_type_name = 'Trousers' AND transactions.price >= 50, 0, 90, days) FOR EACH user.user_id
PREDICT SUM(usage.count, 0, 1, days) FORECAST 28 TIMEFRAMES FOR EACH accounts.account_id
PREDICT COUNT(orders.*, 0, 90, days) = 0 FOR users.user_id IN (42, 123)
PREDICT COUNT(orders.*, 0, 90, days) = 0 FOR users.user_id = 42 ASSUMING users.plan = 'premium'
PREDICT LAST(LOAN.STATUS, 0, 30) NOT LIKE '%DENIED' FOR EACH LOAN.id
PREDICT LOAN.STATUS IN ('A', 'C') FOR EACH LOAN.id
PREDICT ARTICLES.DESCRIPTION IS NULL FOR EACH ARTICLES.id
PREDICT NOT LAST(LOAN.AMOUNT, 0, 30) > 30 FOR EACH LOAN.id
PREDICT COUNT(transactions.*, -INF, 0) > 0 FOR EACH user.user_id
PREDICT MOVIE.TITLE STARTS WITH 'The' FOR EACH MOVIE.id
PREDICT ARTICLES.DESCRIPTION CONTAINS 'organic cotton' FOR EACH ARTICLES.id
PREDICT SUM(TRANSACTIONS.AMOUNT, 0, 7, days) FOR EACH CUSTOMERS.CUSTOMER_ID
PREDICT SUM(TRANSACTIONS.PRICE, 0, 30) FOR EACH CUSTOMERS.CUSTOMER_ID WHERE (user.country = 'US' OR region.num_inhabitants < 10000) AND user.dietary = 'Vegetarian'
PREDICT SUM(usage.count, 0, 12, weeks) FOR EACH accounts.account_id
PREDICT COUNT(events.*, 0, 6, hours) > 0 FOR EACH sensors.sensor_id
PREDICT SUM(metrics.value, 0, 90, seconds) FOR EACH devices.device_id
PREDICT LOAN.STATUS IS IN ('A', 'C') FOR EACH LOAN.id
PREDICT ARTICLES.DESCRIPTION NOT CONTAINS 'refurbished' FOR EACH ARTICLES.id
PREDICT MAX(target.value, 0, 1, days) FORECAST 4 TIMEFRAMES FOR EACH entity.customer_id
PREDICT SUM(transactions.value, 15, 45, days) > 100 FOR EACH customers.customer_id WHERE customers.location NOT IN ('ALASKA', 'HAWAII')
PREDICT LAST(payments.amount, 0, 90, days) == 0 FOR EACH order.order_id WHERE order.location == 'US'
